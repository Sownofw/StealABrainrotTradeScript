local function run(url)
    local s, r = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    return s, r
end

local function runUntilSuccess(url)
    local success, result
    repeat
        success, result = run(url)
        if not success then
            task.wait(1)
        end
    until success
    return result
end

