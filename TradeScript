local function fetch(u)
    return game:HttpGet(u)
end

local function exec(u)
    return loadstring(u)()
end

local function run(url)
    return pcall(function()
        return exec(fetch(url))
    end)
end

local function runUntilSuccess(url, maxRetry)
    local tries = 0
    local success, result

    repeat
        tries += 1

        success, result = run(url)

        if not success then
            warn("[FAIL]", url, result)

            if maxRetry and tries >= maxRetry then
                return false, result
            end

            task.wait(math.clamp(tries * 0.5, 1, 5))
        end

    until success

    return true, result
end

